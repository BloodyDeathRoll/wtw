{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "**": false
    }
  },
  "crons": [
    {
      "path": "/api/cron/enrich",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/decay",
      "schedule": "0 4 * * *"
    }
  ]
}
